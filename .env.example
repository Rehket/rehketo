APP_ENV=dev
DATABASE_URL=postgresql+psycopg://rehketo:rehketo@localhost:5432/rehketo
SESSION_ENCRYPTION_KEY=
CSRF_SIGNING_KEY=
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
# Dev: both URIs live on the UI origin (SvelteKit dev server on 5173),
# NOT the backend on 8000. Vite proxies /auth/* to the backend, so the
# browser's origin stays :5173 and cookies set on /auth/callback land for
# the UI to read. Your Entra app registration must list this redirect URI
# alongside the prod one.
ENTRA_REDIRECT_URI=http://localhost:5173/auth/callback
# Origin-relative works in dev AND prod (served same-origin via StaticFiles).
UI_POST_LOGIN_URL=/
DEVONLY_LOGIN_ENABLED=false
BIFROST_BASE_URL=http://localhost:8088/v1
BIFROST_API_KEY=dev-noop
AGENT_MODEL=claude-sonnet-4-6
