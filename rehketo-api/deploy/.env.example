# Used by docker-compose. Copy to .env and fill secrets.
#
# Note: rehketo-api/.env is loaded by the FastAPI process when running the
# app on the host via `uv run rehketo-serve`. This file (deploy/.env) is
# loaded by docker-compose when running any service in deploy/docker-compose.yaml.
# The `rehketo-api` service in compose reads its settings from THIS file,
# not from rehketo-api/.env, so the full configuration must live here too.

# -----------------------------------------------------------------------------
# Postgres (used by postgres + bifrost + rehketo-api)
# -----------------------------------------------------------------------------
POSTGRES_USER=rehketo
POSTGRES_PASSWORD=rehketo

# -----------------------------------------------------------------------------
# Bifrost
# -----------------------------------------------------------------------------
# Bifrost's at-rest encryption key for stored provider API keys.
# Generate once and NEVER rotate after provider keys are saved in the UI,
# or Bifrost will not be able to decrypt them.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
BIFROST_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# rehketo-api (only needed when running `docker compose up rehketo-api`;
# local `uv run rehketo-serve` reads rehketo-api/.env instead)
# -----------------------------------------------------------------------------
APP_ENV=dev

# Fernet key for encrypting refresh tokens at rest. Generate with:
#   uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_ENCRYPTION_KEY=

# Random string (>= 32 chars) signing CSRF tokens. Generate with:
#   uv run python -c "import secrets; print(secrets.token_urlsafe(48))"
CSRF_SIGNING_KEY=

# Entra (Azure AD) app registration. Values must match an existing
# registration in your tenant; the app need not actually work for devonly
# login to function, but all three have to be set or the app won't start.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# OAuth callback URI — MUST live on the UI origin, not the backend:
#   dev:  http://localhost:5173/auth/callback  (Vite proxy forwards to backend)
#   prod: https://<your-host>/auth/callback     (same origin as deployed API)
# Add both to the Entra app registration's "Redirect URIs" list.
ENTRA_REDIRECT_URI=http://localhost:5173/auth/callback

# Where the backend redirects after a successful login. Relative works in
# both dev and prod (same-origin via StaticFiles mount or Vite proxy).
UI_POST_LOGIN_URL=/

# Enables POST /auth/devonly/login for local iteration. Keep false in prod.
DEVONLY_LOGIN_ENABLED=false

# Bifrost gateway credentials. Base URL is wired via docker-compose to the
# bifrost service's internal hostname; API key is the one you configure in
# the Bifrost admin UI (http://localhost:8088) after saving your provider key.
BIFROST_API_KEY=dev-noop
AGENT_MODEL=claude-sonnet-4-6

# Absolute path INSIDE the rehketo-api container to the built SvelteKit
# bundle (rehketo-ui/build/). When set, FastAPI mounts it at / with SPA
# fallback for same-origin serving. Leave unset if UI dev runs under Vite
# on the host on :5173.
UI_STATIC_DIR=