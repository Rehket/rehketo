{
  "$schema": "https://www.getbifrost.ai/schema",
  "encryption_key": "env.BIFROST_ENCRYPTION_KEY",
  "config_store": {
    "enabled": true,
    "type": "postgres",
    "config": {
      "host": "env.PG_HOST",
      "port": "env.PG_PORT",
      "user": "env.PG_USER",
      "password": "env.PG_PASSWORD",
      "db_name": "env.PG_DB",
      "ssl_mode": "env.PG_SSL_MODE"
    }
  },
  "logs_store": {
    "enabled": true,
    "type": "postgres",
    "config": {
      "host": "env.PG_HOST",
      "port": "env.PG_PORT",
      "user": "env.PG_USER",
      "password": "env.PG_PASSWORD",
      "db_name": "env.PG_DB",
      "ssl_mode": "env.PG_SSL_MODE"
    }
  }
}
